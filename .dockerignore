# Keep the Docker build context small and reproducible.
.git
.claude
.idea
.vscode
.DS_Store

# Build artifacts — the image builds everything itself.
dist/
web/dist/
web/node_modules/
# Host embed dir is ignored; the frontend stage Vite-builds into
# /src/internal/webui/dist and the backend stage copies that tree in.
internal/webui/dist/

# Local runtime files.
*.log
piperouter.yaml.bak
coverage.out
*.test

# Docs and deployment collateral not needed inside the build
# (deploy/piperouter.yaml IS needed — stage 3 copies it).
docs/
PRD.md
deploy/docker-compose.yaml
deploy/Caddyfile
